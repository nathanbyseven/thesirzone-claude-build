{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/home", "destination": "/index.html" },
    { "source": "/about", "destination": "/index.html" },
    { "source": "/pricing", "destination": "/index.html" },
    { "source": "/faq", "destination": "/index.html" },
    { "source": "/contact", "destination": "/index.html" },
    { "source": "/apply", "destination": "/apply.html" }
  ],
  "redirects": [
    { "source": "/index", "destination": "/", "permanent": true },
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/apply.html", "destination": "/apply", "permanent": true }
  ]
}
